# Runs unit tests for this project and reports unit test coverage
# If ran with the '-v' arg, creates and activates a virtual environment and installs requirements
# Requires pyenv to be installed for creating virtual environment.
# Recommended to run this script within a Linux container image

# Run from root directory as: source scripts/run_tests.sh {python-version} [-v]
# Uses the Python version set below if not given

BUILD_VENV=false
PYTHON_VERSION=3.8
NO_REQS=false

# Parse arguments
for arg in "$@" 
do
    # Create and activate venv if '-v' is given
    if [ "$arg" = "-v" ];
    then
        BUILD_VENV=true
    fi
    # Specify Python version
    if [[ "${arg}" =~ ^3.* ]];
    then
        # AWS Python runtime versions: 3.7.17, 3.8.17, 3.9.17, 3.10.12, 3.11.4
        PYTHON_VERSION=$arg
    fi
    # Don't install requirements
    if [ "$arg" = "-n" ];
    then
        NO_REQS=true
    fi
done

# Create and activate virtual environment
if [ $BUILD_VENV = true ]; then
    echo "setting local python version ($PYTHON_VERSION)"
    pyenv install -s $PYTHON_VERSION
    pyenv local $PYTHON_VERSION

    if [ -d ".venv$PYTHON_VERSION" ]; then
        echo "destroying existing virtual env"
        rm -rf ".venv$PYTHON_VERSION"
    fi
    echo "creating virtual environment"
    python -m venv ".venv$PYTHON_VERSION"

    echo "activating virtual environment"
    source ".venv$PYTHON_VERSION/bin/activate"
fi

if [ $NO_REQS = false ]; then
    echo "Installing requirements"
    pip install -U pip
    pip install -r requirements/requirements.local.development.txt
    pip install -r requirements/requirements.testing.txt
    pip list
fi

echo "Running tests"
coverage_files=""

cd functions
# Remove existing combined coverage file if necessary
rm -f .coverage
i=0
coverage_files=""
for d in `ls -d */ | grep lambda`;

    do
    if [ "$d" == 'core_query_method_lambda/' ]; then
        #  process seperately
        continue
    fi
    if [ "$d" == 'core_trigger_executions_lambda/' ]; then
        #this one potentially causing problems
        continue
    fi
        echo $d;
        python -m pytest "$d";
        retVal=$?;
        if [ $retVal -ne 0 ] && [ $retVal -ne 5 ]; then
            echo 'Failure - exiting build process';
            break -1;
        fi
        # Save coverage file
        touch ".coverage_$i"
        mv ".coverage" ".coverage_$i"
        coverage_files="${coverage_files}functions/.coverage_$i "
        echo "";
        i=$((i + 1))
    done

# start of core_query_method_lambda tests
cd core_query_method_lambda
python -m pytest;
retVal=$?;
if [ $retVal -ne 0 ] && [ $retVal -ne 5 ]; then
    echo 'Failure - exiting build process';
    break -1;
fi
touch "../.coverage_$i"
mv ".coverage" "../.coverage_$i"
coverage_files="${coverage_files}functions/.coverage_$i "
i=$((i + 1))
cd ..
# end of core_query_method_lambda tests

cd ..
# Combine coverage files to generate single report for the entire project
echo $coverage_files
coverage combine $coverage_files && coverage report -m
retVal=$?;
if [ $retVal -ne 0 ]; then
    echo 'Unit test coverage under threshold - exiting';
    if [ ! -z "${AWS_ENV}" ]; then
        exit 1
    fi
fi

# Deactivate virtual environment
if [ $BUILD_VENV = true ]; then
    deactivate
fi
